\@writefile{lof}{\contentsline {figure}{\numberline {3.4}{\ignorespaces Motion signals extracted from a single running video (DUNG27). Faint lines show the raw detrended signal; solid lines show the Gaussian-smoothed version ($\sigma =2$). The periodic oscillation visible in all four signals reflects the running cycle; \texttt  {contact\_diff} captures left--right foot-contact asymmetry and is used as the primary cycle-detection driver.}}{15}{figure.caption.13}\protected@file@percent }
\newlabel{fig:motion_signals}{{3.4}{15}{Motion signals extracted from a single running video (DUNG27). Faint lines show the raw detrended signal; solid lines show the Gaussian-smoothed version ($\sigma =2$). The periodic oscillation visible in all four signals reflects the running cycle; \texttt {contact\_diff} captures left--right foot-contact asymmetry and is used as the primary cycle-detection driver}{figure.caption.13}{}}
\newlabel{fig:motion_signals@cref}{{[figure][4][3]3.4}{[1][14][]15}{}{}{}}
